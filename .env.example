# Firebase (Web SDK)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# LINE Login (Web OAuth) — Welcome ページから手動 OAuth する fallback 用
VITE_LINE_LOGIN_CHANNEL_ID=
VITE_LINE_AUTH_FN_URL=https://asia-northeast1-<projectId>.cloudfunctions.net/createLineCustomToken
VITE_LINE_AUTH_LIFF_FN_URL=https://asia-northeast1-<projectId>.cloudfunctions.net/createLiffFirebaseToken
VITE_PREMIUM_CHECKOUT_FN_URL=https://asia-northeast1-<projectId>.cloudfunctions.net/createStripeCheckoutSession

# LIFF (各 LIFF endpoint の ID)
VITE_LIFF_ID_UNITS=
VITE_LIFF_ID_TEST_RANGE=
VITE_LIFF_ID_REPORT=
VITE_LIFF_ID_SETTINGS=
VITE_LIFF_ID_PREMIUM_INFO=
VITE_LIFF_ID_HELP=
VITE_LIFF_ID_PREMIUM_APPLY=
VITE_LIFF_ID_CONTACT=

# お問い合わせフォーム送信先 Cloud Function URL
# 例: https://asia-northeast1-<project-id>.cloudfunctions.net/submitContactForm
VITE_CONTACT_FN_URL=

# プレミアム アーリーアダプター特典の終了日時（ISO 8601、未設定なら特典バナー非表示）
# 例: 2026-07-15T23:59:59+09:00
VITE_PREMIUM_PROMO_END_AT=

# 公式LINE 友だち追加 URL（保護者向け Web LP で使用）
# 未設定の場合は line.me デフォルトリンクにフォールバック
VITE_OFFICIAL_LINE_ADD_FRIEND_URL=
