{
  "trailingSlash": true,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/tsudumon/img/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/tsudumon/ref/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=600"
        }
      ]
    },
    {
      "source": "/tsudumon/wb/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=600"
        }
      ]
    },
    {
      "source": "/((?!assets/|favicon\\.ico|mubista|tsudumon/img/|tsudumon/ref/|tsudumon/wb/|sitemap\\.xml|robots\\.txt).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/tsudumon/dl",
      "destination": "https://asia-northeast1-chatstudy-63477.cloudfunctions.net/tsudumonDownload"
    },
    {
      "source": "/tsudumon/dl/",
      "destination": "https://asia-northeast1-chatstudy-63477.cloudfunctions.net/tsudumonDownload"
    },
    {
      "source": "/mubista",
      "destination": "https://mubista.web.app/"
    },
    {
      "source": "/mubista/",
      "destination": "https://mubista.web.app/"
    },
    {
      "source": "/mubista/:path*",
      "destination": "https://mubista.web.app/:path*"
    },
    {
      "source": "/((?!assets/|typing|tsudumon|mubista|api/|sitemap\\.xml|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
