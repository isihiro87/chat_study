{
  "trailingSlash": true,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/((?!assets/|favicon\\.ico|mubista|sitemap\\.xml|robots\\.txt).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/mubista",
      "destination": "https://mubista.web.app/"
    },
    {
      "source": "/mubista/",
      "destination": "https://mubista.web.app/"
    },
    {
      "source": "/mubista/:path*",
      "destination": "https://mubista.web.app/:path*"
    },
    {
      "source": "/((?!assets/|typing|mubista|sitemap\\.xml|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}
