rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 課金状態・リッチメニュー種別・trial 情報など、Cloud Functions（admin SDK）でのみ
    // 書き換えるべきフィールド。クライアントは読めるが書けない。
    // admin SDK はルールをバイパスするため、Functions 側からは普通に書ける。
    function touchesProtectedUserFields(keys) {
      return keys.hasAny([
        'plan',
        'premiumUntil',
        'richMenuType',
        'lastRichMenuUpdatedAt',
        'planSource',
        'trialStartedAt',
        'trialExpiredAt',
        'lastTrialReminderAt',
        'lastPremiumNudgeAt',
        'lockedMonthlyPrice',
        'stripeCustomerId',
        'stripeSubscriptionId',
        'paidStartedAt',
        'paidEndedAt'
      ]);
    }

    // referrer は流入経路の計測。クライアントは初回（既存ドキュメントに referrer が無い場合）
    // にのみ書き込み可能。上書きは禁止。
    function isFirstReferrerWrite() {
      return !('referrer' in resource.data) || resource.data.referrer == null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'ishimotty.gst@gmail.com';
    }

    // ユーザーは自分のデータのみ読み書き可能
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // 管理者は全ユーザーデータを読み取り可能
      allow read: if isAdmin();

      // 書き込みは「保護フィールドに触っていないこと」+「referrer は初回のみ」を必須にする
      allow create: if request.auth != null && request.auth.uid == userId
        && !touchesProtectedUserFields(request.resource.data.keys());
      allow update: if request.auth != null && request.auth.uid == userId
        && !touchesProtectedUserFields(request.resource.data.diff(resource.data).affectedKeys())
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['referrer'])
            || isFirstReferrerWrite());
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }
    }

    // プレミアム無料トライアル開始リクエスト。
    // クライアントからは自分の uid 名義の trial_start 作成のみ許可。
    // 既存ドキュメントの編集はクライアント側からは不可。
    match /premiumApplications/{applicationId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.applicationType == 'trial_start'
        && request.resource.data.keys().hasOnly([
          'applicationType',
          'uid',
          'lineUserId',
          'displayName',
          'subject',
          'grade',
          'preferredHour',
          'status',
          'createdAt',
          // セールスコピー対応で追加: 申込経路と保護者フラグ
          'source',
          'parentInitiated'
        ])
        && request.resource.data.keys().hasAll([
          'applicationType',
          'uid',
          'lineUserId',
          'status',
          'createdAt'
        ])
        && request.resource.data.lineUserId is string
        && request.resource.data.lineUserId.matches('^U[0-9a-f]{32}$')
        && (!('displayName' in request.resource.data) || request.resource.data.displayName is string)
        && (!('subject' in request.resource.data) || request.resource.data.subject == null || request.resource.data.subject in ['history', 'english'])
        && (!('grade' in request.resource.data) || request.resource.data.grade == null || request.resource.data.grade in ['中1', '中2', '中3'])
        && (!('preferredHour' in request.resource.data) || request.resource.data.preferredHour == null || request.resource.data.preferredHour in [6, 7, 16, 18, 20])
        && (!('source' in request.resource.data) || request.resource.data.source in [
          'trial-day0', 'trial-day1', 'trial-day3', 'trial-day6',
          'trial-day7-morning', 'trial-day7-evening', 'trial-day7-night',
          'post-trial-day8', 'post-trial-day15', 'post-trial-day30',
          'winback-day7', 'winback-day14',
          'first-answer', 'milestone', 'other'
        ])
        && (!('parentInitiated' in request.resource.data) || request.resource.data.parentInitiated is bool)
        && request.resource.data.createdAt is timestamp;
      allow read, update, delete: if isAdmin();
    }

    // プレミアム導線の funnel イベント（クライアント／サーバー両方から記録）。
    // クライアントは自分名義かつ allowlist の eventType のみ create 可能。
    // サーバー側（admin SDK）からは任意の eventType を記録できる（ルールバイパス）。
    match /premiumFunnelEvents/{eventId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.eventType in [
          'liff_premium_info_view',
          'liff_premium_apply_view',
          'liff_premium_apply_submit',
          'liff_units_open',
          'liff_scope_open',
          'liff_scope_save'
        ];
      allow read, update, delete: if isAdmin();
    }

    // LINE 配信用の問題マスタ。クライアントからは読まれず、Cloud Functions
    // （admin SDK）が dailyQuiz / 追加で解く / 苦手復習 で参照する。
    // dev 限定の管理ダッシュボード (/admin/dashboard) から問題別正答率を
    // 閲覧するために admin の読み取りのみ許可。書き込みは Functions のみ。
    match /questions/{questionId} {
      allow read: if isAdmin();
    }

    // ユーザーの回答ログ。書き込みは Cloud Functions（admin SDK）のみで、
    // クライアントからの書き込みは想定しない。管理ダッシュボードのために
    // admin の読み取りのみ許可。
    match /answers/{answerId} {
      allow read: if isAdmin();
    }

    // 月次配信通数の集計。Cloud Functions が書き込み、admin ダッシュボードが
    // 読み取り、monthlyDeliveryReport cron がレポート出力する。
    match /deliveryStats/{yearMonth} {
      allow read: if isAdmin();
    }

    // Instagram コメント→DM→公式LINE 集客キャンペーン定義。
    // 管理ダッシュボードから admin だけが CRUD する。Webhook (admin SDK) も
    // ルールバイパスで参照可能。
    match /igCampaigns/{campaignId} {
      allow read, write: if isAdmin();
    }

    // Instagram コメント受信ログ（冪等性キー兼イベント記録）。書き込みは
    // Cloud Functions（admin SDK）のみ。admin が読み取り可。
    match /igCommentEvents/{commentId} {
      allow read: if isAdmin();
    }

    // Instagram DM 送信結果ログ。書き込みは Cloud Functions のみ。
    match /igDmEvents/{eventId} {
      allow read: if isAdmin();
    }
  }
}
