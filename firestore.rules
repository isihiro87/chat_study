rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 課金状態・リッチメニュー種別・trial 情報など、Cloud Functions（admin SDK）でのみ
    // 書き換えるべきフィールド。クライアントは読めるが書けない。
    // admin SDK はルールをバイパスするため、Functions 側からは普通に書ける。
    function touchesProtectedUserFields(keys) {
      return keys.hasAny([
        'plan',
        'premiumUntil',
        'richMenuType',
        'lastRichMenuUpdatedAt',
        'planSource',
        'trialStartedAt',
        'trialExpiredAt',
        'lastTrialReminderAt',
        'lastPremiumNudgeAt'
      ]);
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'ishimotty.gst@gmail.com';
    }

    // ユーザーは自分のデータのみ読み書き可能
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // 管理者は全ユーザーデータを読み取り可能
      allow read: if isAdmin();

      // 書き込みは「保護フィールドに触っていないこと」を必須にする
      allow create: if request.auth != null && request.auth.uid == userId
        && !touchesProtectedUserFields(request.resource.data.keys());
      allow update: if request.auth != null && request.auth.uid == userId
        && !touchesProtectedUserFields(request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if isAdmin();
      }
    }

    // プレミアム申込（LIFF /premium-apply から書き込み、管理者のみ閲覧・更新）。
    // クライアントからは自分の uid 名義かつ status=pending の場合のみ作成可。
    // 既存ドキュメントの編集はクライアント側からは不可（管理者が手動で承認/却下する想定）。
    match /premiumApplications/{applicationId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    // プレミアム導線の funnel イベント（クライアント／サーバー両方から記録）。
    // クライアントは自分名義かつ allowlist の eventType のみ create 可能。
    // サーバー側（admin SDK）からは任意の eventType を記録できる（ルールバイパス）。
    match /premiumFunnelEvents/{eventId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.eventType in [
          'liff_premium_info_view',
          'liff_premium_apply_view',
          'liff_premium_apply_submit'
        ];
      allow read, update, delete: if isAdmin();
    }
  }
}
